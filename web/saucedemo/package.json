{
    "name": "selenium-mocha-digital-skola",
    "version": "1.0.0",
    "description": "Selenium WebDriver test using Mocha with Mochawesome Reports",
    "type": "module",
    "scripts": {
        "test": "mocha tests --recursive --timeout 60000 --reporter spec",
        "test-mochawesome": "mocha tests --recursive --timeout 60000 --reporter mochawesome",
        "test-simple-html": "mocha tests --recursive --timeout 60000 --reporter mocha-simple-html-reporter --reporter-options output=report.html",
        "test:chrome": "cross-env BROWSER=chrome mocha tests --recursive --timeout 60000 --reporter spec",
        "test:firefox": "cross-env BROWSER=firefox mocha tests --recursive --timeout 60000 --reporter spec"
    },
    "dependencies": {
        "selenium-webdriver": "^4.17.0"
    },
    "devDependencies": {
        "chai": "^4.3.8",
        "cross-env": "^10.1.0",
        "mocha": "^10.4.0",
        "mocha-simple-html-reporter": "^2.0.0",
        "mochawesome": "^7.1.3",
        "pixelmatch": "^7.2.0",
        "pngjs": "^7.0.0"
    }
}
