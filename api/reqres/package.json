{
    "name": "project-automation-mocha",
    "version":"1.0.0",
    "description": "baru coba",
    "type": "module",
    "scripts": {
        "test" : "mocha tests --recursive --timeout 5000 --reporter spec",
        "test-html" : "mocha tests --recursive --timeout 5000 --reporter mocha-simple-html-reporter --reporter-options output=hasil-tes.html",
        "test-json" : "mocha tests --recursive --timeout 5000 --reporter json > hasil-tes.json"
    },
    "dependencies": {
        "node-fetch":"^3.3.1",
        "ajv":"^8.12.0"
    },
    "devDependencies": {
        "mocha" : "^10.2.0",
        "chai" : "^4.3.8",
        "mocha-simple-html-reporter" : "^2.0.0"
    }

}